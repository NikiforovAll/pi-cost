{
  "name": "pi-cost",
  "version": "0.1.1",
  "description": "Cost dashboard for the pi coding agent",
  "keywords": [
    "pi-package",
    "pi-extension",
    "cost",
    "dashboard",
    "litellm",
    "observability"
  ],
  "license": "MIT",
  "author": "nikiforovall",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NikiforovAll/pi-cost.git"
  },
  "bugs": {
    "url": "https://github.com/NikiforovAll/pi-cost/issues"
  },
  "homepage": "https://nikiforovall.github.io/pi-cost/",
  "bin": { "pi-cost": "./server.js" },
  "main": "server.js",
  "files": [
    "server.js",
    "lib/",
    "public/",
    "extensions/",
    "themes/",
    "README.md"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js --open",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": { "optional": true }
  },
  "pi": {
    "extensions": ["./extensions"],
    "image": "https://raw.githubusercontent.com/NikiforovAll/pi-cost/main/assets/overview.png",
    "video": "https://raw.githubusercontent.com/NikiforovAll/pi-cost/main/assets/demo.mp4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
